# ============================================================
# ISEYAA — Ogun State Digital Operating System
# Environment Variables Template  |  NEVER commit .env files
# ============================================================

# --- ENVIRONMENT ---
ENVIRONMENT=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO
SECRET_KEY=your-256-bit-secret-key-here
DEBUG=false

# --- API GATEWAY ---
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
API_GATEWAY_WORKERS=4
ALLOWED_ORIGINS=http://localhost:3000,https://iseyaa.og.gov.ng

# --- SERVICES (internal ports) ---
AUTH_SERVICE_URL=http://auth-service:8001
WALLET_SERVICE_URL=http://wallet-service:8002
EVENTS_SERVICE_URL=http://events-service:8003
LGA_INTELLIGENCE_SERVICE_URL=http://lga-intelligence-service:8004
NOTIFICATIONS_SERVICE_URL=http://notifications-service:8005
AI_LAYER_URL=http://ai-layer:8010

# --- POSTGRESQL (Primary — RDS Multi-AZ) ---
# Format: postgresql+asyncpg://user:password@host:port/db
DATABASE_URL=postgresql+asyncpg://iseyaa_user:CHANGE_ME@localhost:5432/iseyaa_db
DATABASE_URL_SYNC=postgresql://iseyaa_user:CHANGE_ME@localhost:5432/iseyaa_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# --- WALLET SERVICE DB (separate schema for ACID isolation) ---
WALLET_DATABASE_URL=postgresql+asyncpg://iseyaa_wallet:CHANGE_ME@localhost:5432/iseyaa_wallet_db

# --- REDIS (ElastiCache) ---
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_DB=1
REDIS_CACHE_DB=2
REDIS_RATE_LIMIT_DB=3
REDIS_TTL_DEFAULT=3600

# --- AWS CREDENTIALS ---
AWS_REGION=af-south-1
AWS_DISASTER_RECOVERY_REGION=eu-west-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=CHANGE_ME_IN_SECRETS_MANAGER

# --- AWS SERVICES ---
AWS_S3_BUCKET=iseyaa-media-prod
AWS_S3_BUCKET_DOCUMENTS=iseyaa-documents-prod
AWS_S3_CDN_URL=https://cdn.iseyaa.og.gov.ng
AWS_SQS_EVENTS_QUEUE_URL=https://sqs.af-south-1.amazonaws.com/123456789/iseyaa-events
AWS_SQS_NOTIFICATIONS_QUEUE_URL=https://sqs.af-south-1.amazonaws.com/123456789/iseyaa-notifications
AWS_SQS_PAYMENTS_QUEUE_URL=https://sqs.af-south-1.amazonaws.com/123456789/iseyaa-payments
AWS_SNS_PLATFORM_TOPIC_ARN=arn:aws:sns:af-south-1:123456789:iseyaa-platform
AWS_COGNITO_USER_POOL_ID=af-south-1_XXXXXXXXX
AWS_COGNITO_CLIENT_ID=CHANGE_ME
AWS_KMS_KEY_ID=arn:aws:kms:af-south-1:123456789:key/mrk-XXXXXXXX
AWS_SECRETS_MANAGER_PREFIX=iseyaa/prod

# --- GOOGLE CLOUD (Maps / AI / Analytics) ---
GOOGLE_CLOUD_PROJECT_ID=iseyaa-ogun-state
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-service-account.json
GOOGLE_MAPS_API_KEY=CHANGE_ME
GOOGLE_MAPS_GEOCODING_URL=https://maps.googleapis.com/maps/api/geocode/json
FIREBASE_PROJECT_ID=iseyaa-mobile
FIREBASE_SERVER_KEY=CHANGE_ME
FCM_API_URL=https://fcm.googleapis.com/fcm/send

# --- AI / ANTHROPIC ---
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_MODEL=claude-opus-4-20250514
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.1
AI_ORCHESTRATOR_ENABLED=true
AI_AGENT_CONCURRENCY=5

# --- PAYMENTS — PAYSTACK (Primary) ---
PAYSTACK_SECRET_KEY=sk_live_CHANGE_ME
PAYSTACK_PUBLIC_KEY=pk_live_CHANGE_ME
PAYSTACK_WEBHOOK_SECRET=CHANGE_ME
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CALLBACK_URL=https://api.iseyaa.og.gov.ng/v1/payments/paystack/callback

# --- PAYMENTS — FLUTTERWAVE (Secondary / Cross-border) ---
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE_CHANGE_ME
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE_CHANGE_ME
FLUTTERWAVE_WEBHOOK_HASH=CHANGE_ME
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# --- OPEN BANKING (Mono) ---
MONO_SECRET_KEY=live_sk_CHANGE_ME
MONO_BASE_URL=https://api.withmono.com/v2

# --- NIBSS / Direct Transfer ---
NIBSS_BASE_URL=https://nibss-plc.com.ng/api
NIBSS_CLIENT_ID=CHANGE_ME
NIBSS_CLIENT_SECRET=CHANGE_ME

# --- COMMUNICATIONS ---
# Termii (SMS — Nigerian-first)
TERMII_API_KEY=CHANGE_ME
TERMII_SENDER_ID=ISEYAA
TERMII_BASE_URL=https://api.ng.termii.com/api

# SendGrid (Email)
SENDGRID_API_KEY=SG.CHANGE_ME
SENDGRID_FROM_EMAIL=noreply@iseyaa.og.gov.ng
SENDGRID_FROM_NAME=ISEYAA — Ogun State

# Twilio WhatsApp Business
TWILIO_ACCOUNT_SID=ACCHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_WHATSAPP_NUMBER=whatsapp:+234XXXXXXXXXX

# Ably (Real-time events — ride tracking, live scores)
ABLY_API_KEY=CHANGE_ME

# --- IDENTITY / KYC ---
# NIN Verification
NIMC_API_KEY=CHANGE_ME
NIMC_BASE_URL=https://api.nimc.gov.ng/v1
# BVN Verification
BVN_VERIFICATION_API_KEY=CHANGE_ME
BVN_VERIFICATION_URL=https://api.youverify.co/v2

# --- MAPS / ROUTING ---
MAPBOX_TOKEN=pk.eyJ1IjoiY2hhbmdlX21lIn0.CHANGE_ME

# --- RATE LIMITING ---
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_AUTH=20
RATE_LIMIT_PAYMENTS=30
RATE_LIMIT_AI=10
RATE_LIMIT_WINDOW_SECONDS=60

# --- SECURITY ---
JWT_SECRET_KEY=CHANGE_ME_AT_LEAST_256_BITS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
CORS_ALLOW_CREDENTIALS=true
SECURE_COOKIES=true

# --- OBSERVABILITY ---
DATADOG_API_KEY=CHANGE_ME
DATADOG_APP_KEY=CHANGE_ME
DATADOG_SERVICE_NAME=iseyaa
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
SENTRY_ENVIRONMENT=production
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- IGOV / OGIRS (Ogun State Revenue Service) ---
OGIRS_API_KEY=CHANGE_ME
OGIRS_BASE_URL=https://api.ogirs.gov.ng/v1
OGIRS_MERCHANT_ID=CHANGE_ME

# --- UTILITIES ---
IBEDC_API_KEY=CHANGE_ME
IBEDC_BASE_URL=https://api.ibedc.com/v1
EKEDC_API_KEY=CHANGE_ME
EKEDC_BASE_URL=https://api.ekedc.com/v1
OGUN_WATER_API_KEY=CHANGE_ME
OGUN_WATER_BASE_URL=https://api.ogunwater.gov.ng/v1

# --- FEATURE FLAGS ---
FEATURE_WALLET_ENABLED=true
FEATURE_EVENTS_ENABLED=true
FEATURE_LGA_INTELLIGENCE_ENABLED=true
FEATURE_TRANSPORT_ENABLED=false
FEATURE_SPORTS_ENABLED=false
FEATURE_HMO_ENABLED=false
FEATURE_AI_CHATBOT_ENABLED=false
FEATURE_AR_VR_ENABLED=false
